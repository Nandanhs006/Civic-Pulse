# Firebase Phone-Auth web config (client-side, public by design).
# Copy to `.env` and fill in from Firebase console → Project settings → Your apps.
# Leave blank to run the OTP flow in demo/mock mode (no real SMS).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional: point the SPA at a non-same-origin API during dev.
# VITE_API_URL=
