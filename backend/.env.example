# ─────────────────────────────────────────────────────────────────────────────
# Civic Pulse — backend environment. Copy to `backend/.env` and fill in.
# Everything has a working default, so the app runs with an EMPTY .env in demo
# mode. Only set what you want to turn on (real DB, real Firebase, real Gemini).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# Use a throwaway SQLite file instead of Postgres (handy for local dev / tests).
USE_SQLITE=false
# Postgres connection (used when USE_SQLITE is not true). Defaults shown.
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=civic_pulse

# ── Auth / security ─────────────────────────────────────────────────────────
# JWT signing key. CHANGE THIS in any real deployment.
SECRET_KEY=super-secret-token-key-for-civic-pulse-123456

# ── Firebase Phone-OTP (citizen verification) ───────────────────────────────
# The web client sends & confirms the SMS OTP via Firebase; the backend VERIFIES
# the resulting Firebase ID token. Leave BLANK to run OTP in demo/mock mode
# (accepts the demo code 123456 — no real SMS, no verification).
#
# To enable REAL verification, provide a Firebase service-account key:
#   Firebase console → Project settings → Service accounts → Generate new
#   private key. Then set FIREBASE_SERVICE_ACCOUNT to EITHER:
#     • an absolute path to that JSON file, e.g. /etc/secrets/firebase.json, OR
#     • the full JSON contents on one line (useful for Render env vars).
# (Also enable Authentication → Sign-in method → Phone, and add your domains
#  under Authorized domains: localhost + your Render URL.)
FIREBASE_PROJECT_ID=civic-pulse-7af0f
FIREBASE_SERVICE_ACCOUNT=

# ── AI pipeline (optional) ──────────────────────────────────────────────────
# Leave GEMINI_API_KEY blank to use the deterministic mock AI pipeline (free,
# reproducible). Set it to enable real Gemini categorization / STT / spam checks.
GEMINI_API_KEY=

# ── Open data ───────────────────────────────────────────────────────────────
# data.gov.in key for live CPCB air quality. Defaults to a shared sample key.
DATA_GOV_API_KEY=

# ── Redis (rate limiting) ───────────────────────────────────────────────────
# Optional; falls back to an in-memory limiter when Redis is unreachable.
REDIS_HOST=localhost
REDIS_PORT=6379
